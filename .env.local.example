# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# Supabase — supabase.com/dashboard → Project → Settings → API
# Recommended region: Sydney (ap-southeast-2)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=

# Stripe (Week 4) — dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend (waitlist emails) — resend.com → API Keys
RESEND_API_KEY=
